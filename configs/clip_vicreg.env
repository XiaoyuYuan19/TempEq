# Clip-level VICReg: T=4 frames per clip, stride=8, strong augmentation.
RUN_NAME=clip_vicreg
LOSS_MODE=vicreg
SAMPLER=geometric
GEOM_P=0.008
CLIP_LEN=4
CLIP_STRIDE=8
AUG_MODE=strong
PROJ_DIM=2048
PROJ_HIDDEN=2048
PROJ_LAYERS=3
PROJ_BN=1
OPTIMIZER=lars
LR=0.2
WD=1e-6
EPOCHS=100
BATCH_SIZE=64
VICREG_SIM=25.0
VICREG_VAR=25.0
VICREG_COV=1.0
