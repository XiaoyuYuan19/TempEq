# Clip-level PF2 (ours, HEADLINE): T=4 frames per clip, stride=8 (~0.8s span),
# clip-pair gap k ~ Geometric(0.008).
RUN_NAME=clip_pf2
LOSS_MODE=pf2
SAMPLER=geometric
GEOM_P=0.008
CLIP_LEN=4
CLIP_STRIDE=8
AUG_MODE=ssl
PROJ_DIM=8192
PROJ_HIDDEN=8192
PROJ_LAYERS=3
PROJ_BN=1
OPTIMIZER=lars
LR=0.2
WD=1e-6
EPOCHS=100
BATCH_SIZE=64
PF2_DUAL_LR=0.01
PF2_LAM_INIT=0.0
PF2_LAM_MAX=0.0
